# === Required ===
ANTHROPIC_API_KEY=your_anthropic_api_key_here      # From https://console.anthropic.com
HYPERLIQUID_PRIVATE_KEY=0x_your_agent_private_key  # Agent/API wallet private key (signer only)
HYPERLIQUID_VAULT_ADDRESS=0x_your_main_wallet      # Main wallet address that holds funds (agent trades on its behalf)

# === Trading config ===
ASSETS="BTC ETH xyz:CL xyz:GOLD xyz:SILVER xyz:SP500"
INTERVAL="15m"                             # P1.3: ≥15m recommended to cut taker-fee drag
LLM_MODEL="claude-sonnet-4-20250514"      # Claude model to use

# === Risk management (all have sensible defaults) ===
MAX_POSITION_PCT=20                # Max single position as % of portfolio (default: 20)
MAX_LOSS_PER_POSITION_PCT=20       # Force-close at this % loss (default: 20)
MAX_LEVERAGE=10                    # Hard leverage cap (default: 10)
MAX_TOTAL_EXPOSURE_PCT=80          # Max total notional as % of portfolio (default: 80)
DAILY_LOSS_CIRCUIT_BREAKER_PCT=25  # Stop new trades at this daily drawdown % (default: 25)
MANDATORY_SL_PCT=5                 # Auto SL distance % if LLM doesn't set one (default: 5)
MAX_CONCURRENT_POSITIONS=10        # Max simultaneous positions (default: 10)
MIN_BALANCE_RESERVE_PCT=10         # Don't trade below this % of initial balance (default: 10)

# === Phase 1 — stop bleeding ===
# P1.1 stacking guard
STACKING_ALLOW_SCALE_IN=false      # Set true ONLY if you deliberately want to add to winners

# P1.2 per-asset cooldown
COOLDOWN_BARS=3                    # Bars of silence after any open/close/flip (default: 3)

# P1.3 fee reduction — limit entries
ENTRY_ORDER_TYPE=limit             # "limit" (post-only, maker fee) or "market" (taker fee)
ENTRY_LIMIT_TIMEOUT_SEC=90         # Cancel unfilled limit entry after N seconds (default: 90)

# === Phase 2 — strategy tuning ===
# P2.1 ATR-scaled position sizing (atr_ratio = atr3/atr14 on 4h)
ATR_RATIO_HIGH=1.5                 # atr_ratio above this = high-vol regime
ATR_RATIO_LOW=0.7                  # atr_ratio below this = low-vol regime
LOW_SIZE_MULT=0.5                  # Allocation multiplier in high-vol regime (shrink in chop)
HIGH_SIZE_MULT=1.0                 # Allocation multiplier in low-vol regime (NO boost above cap)

# P2.5 trade log + Sharpe
MIN_SHARPE_SAMPLE=10               # Don't compute Sharpe until this many closed trades exist
SHARPE_WINDOW=50                   # Most-recent closed trades used in Sharpe calc

# P2.6 minimum reward:risk on entries
MIN_RR=1.5                         # Reject entries with R:R below this. TP=null bypasses the gate

# P2.7 low-conviction volume gate
MIN_VOL_SPIKE_RATIO=0.5            # Block new entries when 5m vol_spike_ratio < this (dead-tape filter)

# P2.5.4 concise mode
CONCISE_MODE=true                  # Shorter LLM output on hold-all cycles (no open positions); set false to disable

# === Phase 3 — Profit mechanics ===

# P3.1 trailing stop loss
TRAILING_STOP_ENABLED=true         # Master switch for trailing stops
TRAIL_ACTIVATE_R=1.0               # Profit in R-multiples before trailing kicks in (default 1.0 = at breakeven+1R)
TRAIL_DISTANCE_ATR=1.0             # ATR14_4h multiples behind peak price for trailing SL distance

# P3.2 partial take-profit + breakeven SL
PARTIAL_TP_ENABLED=true            # Master switch for scale-out exits
TP1_FRACTION=0.5                   # Fraction of position closed at TP1 (default 0.5 = 50%)
TP1_AT_R=1.0                       # TP1 distance in R-multiples from entry
TP2_AT_R=2.5                       # TP2 distance in R-multiples from entry (remaining position)
MOVE_SL_TO_BREAKEVEN_AT_TP1=true   # Move SL to entry price when TP1 fills
MIN_R_AS_ATR_FRACTION=0.3          # Minimum R as fraction of ATR14_4h; prevents SL clustering on entry

# P3.3 per-asset performance memory
PERF_MEMORY_ENABLED=true           # Inject per-asset win/loss stats into each prompt cycle
PERF_MEMORY_WINDOW=20              # Last N closed trades to include in per-asset stats

# === Phase 4 — Regime layer ===

# P4.1 regime analyzer
REGIME_REFRESH_MINUTES=60          # How often to refresh the daily-candle regime brief (default 60 min)

# P4.2 regime-conditional gate
REGIME_GATE_VOLATILE=true          # Hard-reject new entries on assets classified as 'volatile' regime

# === Optional ===
HYPERLIQUID_NETWORK=mainnet        # mainnet or testnet
# THINKING_ENABLED=false           # Enable Claude extended thinking
# THINKING_BUDGET_TOKENS=10000     # Token budget for thinking
# MAX_TOKENS=4096                  # Max output tokens for Claude
# SANITIZE_MODEL=claude-haiku-4-5-20251001  # Cheap model for output normalization
# API_HOST=0.0.0.0
# API_PORT=3000
